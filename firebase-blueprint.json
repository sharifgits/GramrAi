{
  "entities": {
    "Topic": {
      "title": "Topic",
      "description": "Learning topic (e.g., Nouns, Verbs)",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "order": { "type": "number" }
      },
      "required": ["title", "order"]
    },
    "Subtopic": {
      "title": "Subtopic",
      "description": "Learning subtopic details",
      "type": "object",
      "properties": {
        "topicId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "content": {
          "type": "object",
          "properties": {
            "heading1": { "type": "string" },
            "highlight1": { "type": "string" },
            "para1": { "type": "string" },
            "para2": { "type": "string" },
            "heading2": { "type": "string" },
            "example": { "type": "string" },
            "highlight2": { "type": "string" }
          }
        }
      },
      "required": ["topicId", "title", "order"]
    },
    "SavedWord": {
      "title": "SavedWord",
      "description": "Vocabulary word saved by user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "word": { "type": "string" },
        "definition": { "type": "string" },
        "bengaliMeaning": { "type": "string" },
        "example": { "type": "string" },
        "bengaliExample": { "type": "string" },
        "synonyms": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "word", "bengaliMeaning"]
    },
    "SavedStory": {
      "title": "SavedStory",
      "description": "AI-generated story saved by user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "storyText": { "type": "string" },
        "words": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "word": { "type": "string" },
              "pronunciation": { "type": "string" },
              "meaning": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "storyText"]
    },
    "UserConfig": {
      "title": "UserConfig",
      "description": "User specific configurations",
      "type": "object",
      "properties": {
        "geminiApiKey": { "type": "string" }
      }
    }
  },
  "firestore": {
    "users/{userId}/topics": {
      "schema": { "$ref": "Topic" },
      "description": "User's customized topics"
    },
    "users/{userId}/subtopics": {
      "schema": { "$ref": "Subtopic" },
      "description": "User's customized subtopics"
    },
    "users/{userId}/savedWords": {
      "schema": { "$ref": "SavedWord" },
      "description": "User's saved vocab words"
    },
    "users/{userId}/savedStories": {
      "schema": { "$ref": "SavedStory" },
      "description": "User's saved stories"
    },
    "users/{userId}/config": {
      "schema": { "$ref": "UserConfig" },
      "description": "User specific settings"
    }
  }
}
