rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidTopic(data, userId) {
      return data.keys().hasAll(['title', 'order', 'userId']) &&
             data.userId == userId &&
             data.title is string && data.title.size() <= 200 &&
             data.order is number;
    }

    function isValidSubtopic(data, userId) {
      return data.keys().hasAll(['topicId', 'title', 'order', 'userId']) &&
             data.userId == userId &&
             data.topicId is string &&
             data.title is string && data.title.size() <= 200 &&
             data.order is number;
    }

    function isValidSavedWord(data, userId) {
      return data.keys().hasAll(['userId', 'word', 'definition', 'bengaliMeaning', 'example', 'bengaliExample', 'synonyms', 'createdAt']) &&
             data.userId == userId &&
             data.word is string && data.word.size() <= 100 &&
             data.definition is string && data.definition.size() <= 1000 &&
             data.bengaliMeaning is string && data.bengaliMeaning.size() <= 1000 &&
             data.example is string && data.example.size() <= 1000 &&
             data.bengaliExample is string && data.bengaliExample.size() <= 1000 &&
             data.synonyms is list && data.synonyms.size() <= 10 &&
             data.createdAt == request.time;
    }

    function isValidSavedStory(data, userId) {
      return data.keys().hasAll(['userId', 'storyText', 'words', 'createdAt']) &&
             data.userId == userId &&
             data.storyText is string && data.storyText.size() <= 10000 &&
             data.words is list && data.words.size() <= 20 &&
             data.createdAt == request.time;
    }

    function isValidUserConfig(data) {
      return data.keys().hasAll(['geminiApiKey']) &&
             data.geminiApiKey is string && data.geminiApiKey.size() <= 200;
    }

    // User data rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      match /topics/{topicId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTopic(incoming(), userId);
        allow update: if isOwner(userId) && isValidTopic(incoming(), userId);
        allow delete: if isOwner(userId);
      }

      match /subtopics/{subtopicId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSubtopic(incoming(), userId);
        allow update: if isOwner(userId) && isValidSubtopic(incoming(), userId);
        allow delete: if isOwner(userId);
      }

      match /savedWords/{wordId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSavedWord(incoming(), userId);
        allow delete: if isOwner(userId);
      }

      match /savedStories/{storyId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSavedStory(incoming(), userId);
        allow delete: if isOwner(userId);
      }

      match /extractedFiles/{fileId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      match /config/default {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidUserConfig(incoming());
      }
    }
  }
}
